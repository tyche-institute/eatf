#!/usr/bin/env bash
#
# eatf-verify (v0.1.0 stub)
# SPDX-License-Identifier: Apache-2.0
#
# This is the stub verifier shipped with the v0.1.0 scaffold release.
# The runnable verifier (full signature / hash-chain / timestamp /
# trust-anchor validation) lands in a 0.1.x point release.
#
# What this stub does: walks a test-vector directory and prints what
# the runnable verifier WILL report when it lands, based on the
# vector's verify-expected.txt contract. Useful for wiring the CI
# loop and for downstream implementers who want to assert that their
# own verifier matches the conformance contract.
#
# Usage:
#   eatf-verify <vector-dir>
#   eatf-verify --batch <vectors-root>
#   eatf-verify --version
#
# Exit codes:
#   0  verify=true and the contract said verify=true (or --batch: all consistent)
#   2  verify=false and the contract said verify=false
#   1  any other case (missing file, malformed contract, mismatch)

set -u

readonly VERSION="0.1.0-stub"

die() {
  printf 'eatf-verify: %s\n' "$*" >&2
  exit 1
}

print_version() {
  printf 'eatf-verify %s (stub; runnable verifier lands in 0.1.x)\n' "$VERSION"
}

verify_one() {
  local vector="$1"
  [ -d "$vector" ] || die "not a directory: $vector"

  local manifest="$vector/manifest.json"
  local expected="$vector/verify-expected.txt"

  [ -f "$manifest" ] || die "$vector: missing manifest.json"
  [ -f "$expected" ] || die "$vector: missing verify-expected.txt"

  local verify_line
  verify_line="$(grep -E '^verify=' "$expected" | head -1)"
  case "$verify_line" in
    "verify=true")
      printf 'VECTOR %s\n  verify=true (stub: would validate signature, hash chain, timestamp)\n' "$vector"
      return 0
      ;;
    "verify=false")
      local diagnostic
      diagnostic="$(grep -E '^diagnostic=' "$expected" | head -1 | sed 's/^diagnostic=//')"
      printf 'VECTOR %s\n  verify=false (stub: would reject with diagnostic=%s)\n' "$vector" "${diagnostic:-unknown}"
      return 2
      ;;
    *)
      die "$vector: verify-expected.txt has no verify= line"
      ;;
  esac
}

batch() {
  local root="$1"
  [ -d "$root" ] || die "not a directory: $root"

  local pass_count=0
  local fail_count=0
  local mismatch=0

  while IFS= read -r -d '' vec; do
    case "$vec" in
      "$root"/valid/*)
        verify_one "$vec"
        rc=$?
        if [ "$rc" -eq 0 ]; then
          pass_count=$((pass_count+1))
        else
          printf '  ERROR: valid vector did not report verify=true\n' >&2
          mismatch=$((mismatch+1))
        fi
        ;;
      "$root"/invalid/*)
        verify_one "$vec"
        rc=$?
        if [ "$rc" -eq 2 ]; then
          fail_count=$((fail_count+1))
        else
          printf '  ERROR: invalid vector did not report verify=false\n' >&2
          mismatch=$((mismatch+1))
        fi
        ;;
    esac
  done < <(find "$root" -mindepth 2 -maxdepth 2 -type d -print0 | sort -z)

  printf '\nSummary: %d valid vectors verified, %d invalid vectors rejected, %d contract mismatches.\n' \
    "$pass_count" "$fail_count" "$mismatch"

  [ "$mismatch" -eq 0 ] || return 1
  return 0
}

main() {
  case "${1:-}" in
    --version|-V)
      print_version
      ;;
    --batch)
      shift
      [ $# -eq 1 ] || die "usage: eatf-verify --batch <vectors-root>"
      batch "$1"
      ;;
    --help|-h|"")
      cat <<'EOF'
eatf-verify (v0.1.0 stub)

Usage:
  eatf-verify <vector-dir>           Verify a single test-vector directory.
  eatf-verify --batch <vectors-root> Run conformance against the test-vectors/ tree.
  eatf-verify --version              Print version.

The v0.1.0 build is a stub: it reports what the runnable verifier
will report when it lands, based on each vector's verify-expected.txt.
The runnable verifier (signature, hash chain, RFC 3161 timestamp,
trust anchor validation) lands in a 0.1.x point release.
EOF
      ;;
    *)
      verify_one "$1"
      ;;
  esac
}

main "$@"
